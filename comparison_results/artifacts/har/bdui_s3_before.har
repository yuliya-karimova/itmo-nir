            "size": 3392,
            "mimeType": "application/json",
            "text": "{\"id\":\"home\",\"title\":\"Главная страница\",\"blocks\":[{\"id\":\"3f5e26fb-16b0-4760-90d0-0ed661aea043\",\"type\":\"banner\",\"hidden\":false,\"title\":\"Добро пожаловать на наш сайт!\",\"subtitle\":\"Используем современные технологии Backend Driven UI Demo\",\"imageUrl\":\"https://img.freepik.com/free-vector/abstract-paper-style-background_23-2150744378.jpg?semt=ais_hybrid&w=740&q=80\",\"buttonText\":\"Узнать больше\",\"buttonLink\":\"/info\"},{\"id\":\"block-1766502541124\",\"type\":\"buttons\",\"hidden\":false,\"title\":\"\",\"description\":\"\",\"buttons\":[{\"id\":\"buttons-1766502556074\",\"text\":\"info\",\"link\":\"/info\",\"style\":\"primary\"},{\"id\":\"buttons-1766502614992\",\"text\":\"hello\",\"link\":\"/hello\",\"style\":\"secondary\"}]},{\"id\":\"9c20cf43-acab-4e5c-b153-abf5ee10941d\",\"type\":\"text\",\"hidden\":false,\"title\":\"О проекте\",\"content\":\"Это демонстрационное приложение показывает возможности Backend Driven UI. Контент страницы управляется через бэкенд и может быть изменен без пересборки фронтенда.\"},{\"id\":\"block-1766499574387\",\"type\":\"banner\",\"hidden\":false,\"title\":\"BFF Banner\",\"subtitle\":\"Стейт задаётся на BFF\",\"imageUrl\":\"https://image.slidesdocs.com/responsive-images/background/web-development-and-app-programming-with-seo-friendly-design-on-computer-powerpoint-background_8ad84ff8f9__960_540.jpg\",\"buttonText\":\"Подробнее\",\"buttonLink\":\"/info\"},{\"id\":\"25a37f7d-0cc6-4d50-b195-6df643faccb2\",\"type\":\"cards\",\"hidden\":false,\"title\":\"Наши возможности\",\"cards\":[{\"id\":\"b637e78c-6fcb-4e72-9d79-e5d0a73d0da8\",\"title\":\"Динамический контент\",\"description\":\"Контент управляется через бэкенд\",\"imageUrl\":\"https://media.proglib.io/posts/2021/02/24/5ccab15a3f7623fe3283f1907fd3cd2d.webp\"},{\"id\":\"96848470-980a-4cf0-90bc-b4c291096ce6\",\"title\":\"Гибкая настройка\",\"description\":\"Легко добавлять и изменять блоки\",\"imageUrl\":\"https://static.tildacdn.com/tild3831-3535-4932-a662-656464333136/templates2.jpg\"},{\"id\":\"ad39e45c-9d88-4db7-84cf-34e27a8b4ac2\",\"title\":\"Быстрое обновление\",\"description\":\"Изменения применяются мгновенно\",\"imageUrl\":\"https://daily.wordreference.com/wp-content/uploads/2017/04/fast.jpg\"}]},{\"id\":\"block-1766499957561\",\"type\":\"banner\",\"hidden\":false,\"title\":\"BFF Banner\",\"subtitle\":\"Стейт задаётся на BFF\",\"imageUrl\":\"https://image.slidesdocs.com/responsive-images/background/web-development-and-app-programming-with-seo-friendly-design-on-computer-powerpoint-background_8ad84ff8f9__960_540.jpg\",\"buttonText\":\"Подробнее\",\"buttonLink\":\"/info\"},{\"id\":\"block-1766502000405\",\"type\":\"banner\",\"hidden\":false,\"title\":\"Travel Banner\",\"subtitle\":\"Мой кастомный баннер на основе стандартного баннера\",\"imageUrl\":\"https://img.freepik.com/free-photo/person-traveling-enjoying-their-vacation_23-2151383050.jpg?semt=ais_hybrid&w=740\",\"buttonText\":\"Подробнее\",\"buttonLink\":\"/info\"},{\"id\":\"block-1769352053713\",\"type\":\"text\",\"hidden\":false,\"title\":\"Новое объявление\",\"content\":\"Мы рады сообщить о запуске нового функционала!\"}]}"
